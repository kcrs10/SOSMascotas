
/*
  # Anti-Clickjacking (CWE-1021 / WASC-15)
  # Evita que la app sea embebida en iframes de otros dominios
  X-Frame-Options: DENY
  Content-Security-Policy: frame-ancestors 'none'

  # X-Content-Type-Options
  # Evita que el navegador adivine el tipo MIME (sniffing)
  X-Content-Type-Options: nosniff

  # Strict-Transport-Security (HSTS)
  # Fuerza HTTPS por 1 año, incluye subdominios
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload

  # Cross-Domain / Referrer Policy
  # Controla qué información se envía en cabecera Referer
  Referrer-Policy: strict-origin-when-cross-origin

  # Permissions Policy
  # Deshabilita APIs del navegador que la app no usa
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=(), usb=()

  # Content Security Policy completa
  # Permite recursos solo de orígenes conocidos
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://unpkg.com https://cdnjs.cloudflare.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://unpkg.com https://cdnjs.cloudflare.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob: https://*.supabase.co https://*.supabase.in https://lh3.googleusercontent.com https://*.tile.openstreetmap.org; connect-src 'self' https://*.supabase.co wss://*.supabase.co; frame-ancestors 'none'; base-uri 'self'; form-action 'self'

  # Cross-Origin Resource Policy
  Cross-Origin-Resource-Policy: same-origin

  # Cross-Origin Opener Policy
  Cross-Origin-Opener-Policy: same-origin-allow-popups

/assets/*
  # Assets estáticos: cache largo + inmutables
  Cache-Control: public, max-age=31536000, immutable

/sw.js
  # Service Worker: sin cache para que se actualice siempre
  Cache-Control: no-cache, no-store, must-revalidate

/manifest.json
  # Manifest PWA: cache corto
  Cache-Control: public, max-age=3600
