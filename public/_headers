# ============================================
# Cabeceras de seguridad — SOS Mascotas
# Basado en reporte OWASP ZAP 2026-06-06
# ============================================

/*
  # Anti-Clickjacking
  X-Frame-Options: DENY

  # MIME sniffing
  X-Content-Type-Options: nosniff

  # HSTS — fuerza HTTPS por 1 año
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload

  # Referrer
  Referrer-Policy: strict-origin-when-cross-origin

  # Permisos de APIs del navegador
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=(), usb=()

  # Cross-Origin
  Cross-Origin-Opener-Policy: same-origin-allow-popups
  Cross-Origin-Resource-Policy: cross-origin

  # CSP — resuelve Cross-Domain y SRI Missing
  # unsafe-inline necesario para React (estilos inline) y SW registro
  # Se agregan todos los orígenes externos conocidos
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob: https://*.supabase.co https://*.supabase.in https://lh3.googleusercontent.com https://*.tile.openstreetmap.org https://unpkg.com; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://cloudflareinsights.com; frame-src https://www.openstreetmap.org; frame-ancestors 'none'; base-uri 'self'; form-action 'self' https://accounts.google.com; upgrade-insecure-requests

  # Cache por defecto para HTML — no cachear
  Cache-Control: no-store, no-cache, must-revalidate

/assets/*
  Cache-Control: public, max-age=31536000, immutable
  X-Content-Type-Options: nosniff

/sw.js
  Cache-Control: no-cache, no-store, must-revalidate
  X-Content-Type-Options: nosniff

/manifest.json
  Cache-Control: public, max-age=3600
  X-Content-Type-Options: nosniff
  Access-Control-Allow-Origin: *

/robots.txt
  Cache-Control: public, max-age=86400
  X-Content-Type-Options: nosniff

/favicon.svg
  Cache-Control: public, max-age=604800
  X-Content-Type-Options: nosniff
